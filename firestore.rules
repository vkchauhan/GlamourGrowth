rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bookings
    // Fields:
    //   - client_id: string (optional)
    //   - client_name: string (required)
    //   - client_phone: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - total_amount: number (required)
    //   - services: list (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: clients
    // Fields:
    //   - name: string (required)
    //   - phone: string (optional)
    //   - createdAt: timestamp (required)
    //   - lastBookingAt: timestamp (optional)
    // Fields:
    //   - service_name: string (required)
    //   - duration_minutes: number (required)
    //   - price: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document: availability
    // Fields:
    //   - availability: list (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: expenses
    // Fields:
    //   - user_id: string (required)
    //   - amount: number (required)
    //   - category: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - notes: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidBooking(data) {
      return data.client_name is string && data.client_name.size() > 0 && data.client_name.size() < 100 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.total_amount is number && data.total_amount >= 0;
    }

    function isValidService(data) {
      return data.service_name is string && data.service_name.size() > 0 && data.service_name.size() < 100 &&
             data.duration_minutes is number && data.duration_minutes > 0 &&
             data.price is number && data.price >= 0;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['user_id', 'amount', 'category', 'date', 'createdAt']) &&
             data.keys().hasOnly(['user_id', 'amount', 'category', 'date', 'notes', 'createdAt']) &&
             data.user_id is string && data.user_id == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.category is string && data.category.size() > 0 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.createdAt is string &&
             (!('notes' in data) || data.notes is string);
    }

    // Bookings: Anyone can create (public booking), but only authenticated users can read/update/delete
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAuthenticated();
    }

    // Clients: Only authenticated users can read/write
    match /clients/{clientId} {
      allow read, write: if isAuthenticated();
    }

    // Services: Anyone can read (public booking), but only authenticated users can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidService(request.resource.data);
    }

    // Settings: Anyone can read (public booking), but only authenticated users can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Daily Growth Tasks: Read-only for authenticated users
    match /daily_growth_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable via console/admin
    }

    // User Daily Tasks: Only owner can read/write
    match /user_daily_tasks/{taskId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
    }

    // Analytics Events: Only owner can write, only owner can read
    match /analytics_events/{eventId} {
      allow read, create: if isAuthenticated() && (resource == null || resource.data.user_id == request.auth.uid) && (request.resource == null || request.resource.data.user_id == request.auth.uid);
    }

    // Expenses: Only owner can read/write
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && resource.data.user_id == request.auth.uid;
      allow create: if isAuthenticated() && isValidExpense(request.resource.data);
      allow update: if isAuthenticated() && resource.data.user_id == request.auth.uid && 
                      isValidExpense(request.resource.data) &&
                      request.resource.data.user_id == resource.data.user_id &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }
  }
}

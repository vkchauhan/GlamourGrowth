rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bookings
    // Fields:
    //   - name: string (required)
    //   - phone: string (optional)
    //   - date: string (required, YYYY-MM-DD)
    //   - booking_time: string (optional)
    //   - price: number (required)
    //   - services: list (optional)
    //   - status: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Fields:
    //   - service_name: string (required)
    //   - duration_minutes: number (required)
    //   - price: number (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document: availability
    // Fields:
    //   - availability: list (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidBooking(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.price is number && data.price >= 0;
    }

    function isValidService(data) {
      return data.service_name is string && data.service_name.size() > 0 && data.service_name.size() < 100 &&
             data.duration_minutes is number && data.duration_minutes > 0 &&
             data.price is number && data.price >= 0;
    }

    // Bookings: Anyone can create (public booking), but only authenticated users can read/update/delete
    match /bookings/{bookingId} {
      allow create: if isValidBooking(request.resource.data);
      allow read, update, delete: if isAuthenticated();
    }

    // Services: Anyone can read (public booking), but only authenticated users can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidService(request.resource.data);
    }

    // Settings: Anyone can read (public booking), but only authenticated users can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Daily Growth Tasks: Read-only for authenticated users
    match /daily_growth_tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manageable via console/admin
    }

    // User Daily Tasks: Only owner can read/write
    match /user_daily_tasks/{taskId} {
      allow read, write: if isAuthenticated() && request.auth.uid == resource.data.user_id;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
    }

    // Analytics Events: Only owner can write, only owner can read
    match /analytics_events/{eventId} {
      allow read, create: if isAuthenticated() && (request.auth.uid == resource.data.user_id || request.auth.uid == request.resource.data.user_id);
    }
  }
}

{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A client booking for makeup services",
      "type": "object",
      "properties": {
        "booking_id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "booking_time": { "type": "string" },
        "price": { "type": "number" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["confirmed", "pending", "cancelled"] },
        "client_notes": { "type": "string", "description": "Special instructions or important information about the client" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "price"]
    },
    "Service": {
      "title": "Service",
      "description": "A makeup service offered by the artist",
      "type": "object",
      "properties": {
        "service_id": { "type": "string" },
        "service_name": { "type": "string" },
        "duration_minutes": { "type": "number" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["service_name", "price"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Artist settings like availability",
      "type": "object",
      "properties": {
        "availability": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day_of_week": { "type": "integer" },
              "start_time": { "type": "string" },
              "end_time": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyGrowthTask": {
      "title": "DailyGrowthTask",
      "description": "A task for the artist to grow their business",
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "title_en": { "type": "string" },
        "title_hi": { "type": "string" },
        "body_en": { "type": "string" },
        "body_hi": { "type": "string" },
        "trigger_type": { "type": "string", "enum": ["booking_insight", "generic"] },
        "trigger_condition": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title_en", "body_en"]
    },
    "UserDailyTask": {
      "title": "UserDailyTask",
      "description": "A task assigned to a specific user for a specific day",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "task_id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "points": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "task_id", "status", "date"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "description": "An event logged for analytics purposes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "event_type": { "type": "string" },
        "task_id": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "event_type", "createdAt"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "Booking",
      "description": "Collection of client bookings"
    },
    "services": {
      "schema": "Service",
      "description": "Collection of services offered"
    },
    "settings/availability": {
      "schema": "Settings",
      "description": "Artist availability settings"
    },
    "daily_growth_tasks": {
      "schema": "DailyGrowthTask",
      "description": "Master list of growth tasks"
    },
    "user_daily_tasks": {
      "schema": "UserDailyTask",
      "description": "Tasks assigned to users"
    },
    "analytics_events": {
      "schema": "AnalyticsEvent",
      "description": "Logs of user activity and system events"
    }
  }
}

{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A client booking for makeup services",
      "type": "object",
      "properties": {
        "booking_id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "price": { "type": "number" },
        "advance_paid": { "type": "number" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "service_id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "status": { "type": "string", "enum": ["inquiry", "confirmed", "completed", "cancelled"] },
        "photos": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sessionNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "price", "status"]
    },
    "Client": {
      "title": "Client",
      "description": "A client of the makeup artist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "skinType": { "type": "string" },
        "preferences": { "type": "string" },
        "notes": { "type": "string" },
        "totalSpend": { "type": "number" },
        "visitCount": { "type": "number" },
        "lastBookingAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Service": {
      "title": "Service",
      "description": "A makeup service offered by the artist",
      "type": "object",
      "properties": {
        "service_id": { "type": "string" },
        "service_name": { "type": "string" },
        "duration_minutes": { "type": "number" },
        "price": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["service_name", "price"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Artist settings like availability",
      "type": "object",
      "properties": {
        "availability": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day_of_week": { "type": "integer" },
              "start_time": { "type": "string" },
              "end_time": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "DailyGrowthTask": {
      "title": "DailyGrowthTask",
      "description": "A task for the artist to grow their business",
      "type": "object",
      "properties": {
        "task_id": { "type": "string" },
        "title_en": { "type": "string" },
        "title_hi": { "type": "string" },
        "body_en": { "type": "string" },
        "body_hi": { "type": "string" },
        "trigger_type": { "type": "string", "enum": ["booking_insight", "generic"] },
        "trigger_condition": { "type": "string" },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title_en", "body_en"]
    },
    "UserDailyTask": {
      "title": "UserDailyTask",
      "description": "A task assigned to a specific user for a specific day",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "task_id": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "points": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "task_id", "status", "date"]
    },
    "AnalyticsEvent": {
      "title": "AnalyticsEvent",
      "description": "An event logged for analytics purposes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "event_type": { "type": "string" },
        "task_id": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "event_type", "createdAt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense recorded by the artist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "amount", "category", "date"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "The profile of the makeup artist",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "expertise": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "number" },
        "areas": { "type": "array", "items": { "type": "string" } },
        "bio": { "type": "string" },
        "profileImage": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name"]
    }
  },
  "firestore": {
    "bookings": {
      "schema": "Booking",
      "description": "Collection of client bookings"
    },
    "clients": {
      "schema": "Client",
      "description": "Collection of clients"
    },
    "services": {
      "schema": "Service",
      "description": "Collection of services offered"
    },
    "settings/availability": {
      "schema": "Settings",
      "description": "Artist availability settings"
    },
    "daily_growth_tasks": {
      "schema": "DailyGrowthTask",
      "description": "Master list of growth tasks"
    },
    "user_daily_tasks": {
      "schema": "UserDailyTask",
      "description": "Tasks assigned to users"
    },
    "analytics_events": {
      "schema": "AnalyticsEvent",
      "description": "Logs of user activity and system events"
    },
    "expenses": {
      "schema": "Expense",
      "description": "Collection of business expenses"
    },
    "artist_profiles": {
      "schema": "UserProfile",
      "description": "Collection of artist profiles"
    }
  }
}
